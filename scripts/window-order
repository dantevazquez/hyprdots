#!/bin/bash

# 1. Get current active workspace
active_ws=$(hyprctl activeworkspace -j | jq '.id')

# 2. Get clients in their natural (creation) order
# 3. Filter for only those on the active workspace
# 4. Extract the Nth address
window_address=$(hyprctl clients -j | jq -r "
  [ .[] | select(.workspace.id == $active_ws) ] 
  | .[$(( ${1} - 1 ))].address")

# 5. Focus the window
if [ "$window_address" != "null" ]; then
    hyprctl dispatch focuswindow address:"$window_address"
fi
